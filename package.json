{
  "name": "micahkepe-website",
  "homepage": "https://micahkepe.com/",
  "version": "2.0.0",
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "format": "prettier --write index.html src/ styles/",
    "check": "tsc",
    "doc": "typedoc --entryPointStrategy expand src/ types/",
    "test": "cypress run -b chrome",
    "report": "nyc report",
    "clean": "rm -rf build/*",
    "predeploy": "npm run clean && && npm run build",
    "deploy": "gh-pages -d build -m 'deploying to gh-pages'"
  },
  "author": "Micah Kepe",
  "license": "MIT",
  "browserslist": "defaults",
  "devDependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "gh-pages": "^6.1.1",
    "json-schema-to-ts": "^3.1.1",
    "prettier": "^3.4.1",
    "typedoc": "^0.27.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.1"
  },
  "engines": {
    "node": ">=20.11.1"
  }
}
